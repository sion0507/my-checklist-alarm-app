# Copy these values into your hosting provider environment (do not commit real secrets).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_SENDER_ENABLED=false
# Existing test flag remains supported for immediate test-push deployments.
PUSH_TEST_SENDER_ENABLED=false

# Vercel KV / Upstash Redis REST durable storage. Use one pair.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional for manual cron invocation outside Vercel Cron.
CRON_SECRET=
