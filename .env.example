# Web Push / deployment secrets for public HTTPS deployments.
# Do not commit real secret values. Configure these in the hosting provider dashboard/CLI.

# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Set to true only after VAPID keys and a real sender are configured in production.
PUSH_TEST_SENDER_ENABLED=false

# Optional/provider-specific durable storage binding/URL for push subscriptions and scheduled jobs.
# The current in-repo serverless adapter is in-memory only; use a platform KV/table binding for production durability.
PUSH_SUBSCRIPTION_STORE_URL=
