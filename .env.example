# Web Push VAPID keys for the minimal push backend/subscription flow.
# Generate a pair with a Web Push tooling command such as `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Optional deployment/runtime values for a free-tier backend adapter.
# The current checked-in backend module stores only subscription endpoint/keys and minimal metadata;
# use a platform KV/table binding for durable production storage if serverless memory is not persistent.
PUSH_SUBSCRIPTION_STORE_URL=
PUSH_TEST_SENDER_ENABLED=false
